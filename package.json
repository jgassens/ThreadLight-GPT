{
  "name": "threadlight",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "description": "Local-only Safari WebExtension core for keeping long ChatGPT web threads lighter in Safari.",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/build-extension.mjs --target=safari",
    "build:safari": "node scripts/build-extension.mjs",
    "build:dev": "node scripts/build-extension.mjs --target=safari --dev",
    "check:native": "node scripts/check-native-resources.mjs",
    "sync:native": "node scripts/sync-native-resources.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:safari:zip": "node scripts/package-safari.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build:safari && npm run check:native"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
